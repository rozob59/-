rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPERS ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/members/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(memberId) {
      return isSignedIn() && request.auth.uid == memberId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- COLLECTIONS ---

    match /members/{memberId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(memberId) || isAdmin();
      allow update: if isAdmin() || (isOwner(memberId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
      allow delete: if isAdmin();
    }

    match /books/{bookId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /borrows/{borrowId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.memberId == request.auth.uid);
      
      // Forces users to query by their own memberId
      allow list: if isAdmin() || (isSignedIn() && resource.data.memberId == request.auth.uid);
      
      allow create: if isSignedIn() 
        && request.resource.data.memberId == request.auth.uid
        && getAfter(/databases/$(database)/documents/books/$(request.resource.data.bookId)).data.available == false;
      
      allow update: if isAdmin() || (
        isSignedIn() 
        && resource.data.memberId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'actualReturnDate'])
        && getAfter(/databases/$(database)/documents/books/$(resource.data.bookId)).data.available == true
      );
      
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow write: if isAdmin();
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
